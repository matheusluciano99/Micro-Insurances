# =============================================================================
# .env.example — copie para .env e preencha o que estiver com <...>
#   cp .env.example .env
# O .env é gitignored (NÃO commitar segredos). Este arquivo é só template.
# =============================================================================

# --- Rede --------------------------------------------------------------------
# Sepolia. Pegue um RPC em https://infura.io ou https://alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<SEU_PROJECT_ID>
CHAIN_ID=11155111

# --- Contratos já deployados na Sepolia (verificados no Etherscan) -----------
# Endereços públicos — o frontend usa estes para ler/escrever on-chain.
CROP_INSURANCE_ADDRESS=0xd786BAD5D896938E384d6C110f5d6bc44BF9a7ed
MOCK_STABLECOIN_ADDRESS=0x629B047D6d637Ae058d9B6D24308f8116FdB5Ff6
WEATHER_ORACLE_ADDRESS=0x9b3ccC0007e6a2A6AeEbc2bf84df1A01b2723c05
NASA_CONSUMER_ADDRESS=0xcd36E43CEB04986358A5bbC6883492061AD6a9bF

# --- Frontend (wagmi/viem) ---------------------------------------------------
# Se usar Vite, exponha com prefixo VITE_ (ex.: VITE_CROP_INSURANCE_ADDRESS).
# ABIs: rode `forge build` -> out/<Contrato>.sol/<Contrato>.json (campo .abi)
#       ou copie do Etherscan (contratos verificados).

# --- Scripts / deploy (opcional — só quem roda forge script) ----------------
# Chainlink Functions subscription (https://functions.chain.link). Necessário
# para o NasaRainfallConsumer.requestRainfall puxar a chuva da NASA POWER.
SUBSCRIPTION_ID=<id_da_subscription>
# Verificação no Etherscan (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=<sua_api_key_etherscan>
